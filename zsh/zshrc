# Fix Python 3.13 SSL cert verification on macOS
# OpenSSL's compiled-in default path doesn't resolve the certifi symlink;
# setting SSL_CERT_FILE explicitly makes urllib and all SSL contexts work.
export SSL_CERT_FILE="/Library/Frameworks/Python.framework/Versions/3.13/lib/python3.13/site-packages/certifi/cacert.pem"

# Claude Code tmux session manager
# cc        — start claude in current pane (tmux) or create/attach claude-tmux session
# cc <kw>   — cd via zoxide, start claude (current pane if in tmux, else new window)
cc() {
  local session="claude-tmux"
  if [ -n "$TMUX" ]; then
    # Already inside tmux — run claude in the current pane
    if [ -n "$1" ]; then
      local dir
      dir=$(zoxide query "$1" 2>/dev/null) || dir=~/Code/life
      cd "$dir"
    fi
    claude --dangerously-skip-permissions
  elif [ -z "$1" ]; then
    # Outside tmux, no arg: create or attach
    if tmux has-session -t "$session" 2>/dev/null; then
      tmux attach -t "$session"
    else
      tmux new-session -s "$session" -c ~/Code/life -n "main" "claude --dangerously-skip-permissions"
    fi
  else
    # Outside tmux, with arg: new window in session
    local name="$1"
    local dir
    dir=$(zoxide query "$name" 2>/dev/null) || dir=~/Code/life
    if ! tmux has-session -t "$session" 2>/dev/null; then
      tmux new-session -s "$session" -c "$dir" -n "$name" "claude --dangerously-skip-permissions"
    else
      tmux new-window -t "$session" -n "$name" -c "$dir" "claude --dangerously-skip-permissions"
      tmux attach -t "$session"
    fi
  fi
}

# Claude skills CLI tools
export PATH="$HOME/Code/claude-skills/bin:$PATH"
